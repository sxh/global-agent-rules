{
  "$schema": "https://opencode.ai/config.json",
  "model": "my-deepseek/deepseek-v4-flash",
  "default_agent": "stepwise",
  "provider": {
    "my-deepseek": {
      "name": "My DeepSeek",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://api.deepseek.com/v1",
        "apiKey": "{env:OPENCODE_DEEPSEEK_API_KEY}"
      },
      "models": {
        "deepseek-v4-flash": { "id": "deepseek-v4-flash" }
      }
    }
  },
  "disabled_providers": ["deepseek"],
  "plugin": ["~/.config/opencode/plugins/pcp.ts"],
  "lsp": {
    "jdtls": {
      "disabled": true
    }
  }
}
